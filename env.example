# Copy to .env.local and fill in values

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Classic PAT: enable "read:user" (enough for contributions + public pinned repos)
# Fine-grained: Account permissions → Profile → Read-only
GITHUB_TOKEN=

# Formspree form ID (the part after /f/ in your endpoint URL)
# Quick claim link:
# https://formspree.io/claim?name=Portfolio+Contact&project=hammad-portfolio&field.name=text,required,maxlength:100&field.email=email,required&field.message=text,required,maxlength:2000&action.email=hammad.node@gmail.com
NEXT_PUBLIC_FORMSPREE_FORM_ID=
